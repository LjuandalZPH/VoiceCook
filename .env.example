# Supabase: public browser-safe credentials for catalog/profile sync.
# Use the publishable key from Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"
# Optional compatibility fallback if your project still labels it as anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Gemini: recipe generation (https://aistudio.google.com/apikey).
# gemini-2.0-flash is deprecated; the app tries 2.5-flash, 2.5-flash-lite, 1.5-flash.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
# Optional: force a specific model (e.g. gemini-2.5-flash).
# GEMINI_MODEL="gemini-2.5-flash"
